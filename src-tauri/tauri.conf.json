{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Terrain Puzzle",
  "version": "0.1.0",
  "identifier": "com.theatrus.terrain-puzzle",
  "build": {
    "beforeDevCommand": "npm run desktop:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run desktop:build",
    "frontendDist": "../dist-desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Terrain Puzzle Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:38787; img-src 'self' data: https://tile.openstreetmap.org; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "GraphicsAndDesign",
    "shortDescription": "Create printable terrain puzzles from real map data.",
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
